{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(jobflow apply-live *)",
      "Bash(.venv/bin/jobflow apply-live *)",
      "Bash(python -m jobflow.cli apply-live *)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm -rf *)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/*.pem)",
      "Read(~/.ssh/**)"
    ]
  }
}
